# ── IMPORTANT: Ask your backend partner to add CORS middleware to each service ─
# Each service (auth:8001, incidents:8002, dispatch:8003, analytics:8004) needs:
#   allow_origins=["http://localhost:5173", "https://YOUR_VERCEL_URL"]

# ── Service URLs ────────────────────────────────────────────────────────────────
# Leave ALL empty to use mock/demo mode.
# Set each one when the corresponding backend service is ready.
VITE_AUTH_URL=
VITE_INCIDENT_URL=
VITE_DISPATCH_URL=
VITE_ANALYTICS_URL=

# WebSocket base URL for real-time vehicle tracking (e.g. ws://localhost:8003)
VITE_WS_URL=
